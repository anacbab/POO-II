<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="392.0" prefWidth="318.0" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/24.0.1" fx:controller="br.edu.ifsc.fln.prjjavafx1.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="welcomeText" />
   <AnchorPane prefHeight="501.0" prefWidth="278.0">
      <children>
         <Button layoutX="68.0" layoutY="236.0" mnemonicParsing="false" onAction="#btOnAction" text="ok" />
         <Button layoutX="164.0" layoutY="236.0" mnemonicParsing="false" onAction="#btLimparOnAction" text="Limpar" />
         <Label fx:id="lbSobrenome" layoutX="25.0" layoutY="111.0" text="Sobrenome" />
         <Label fx:id="lbNome" layoutX="49.0" layoutY="74.0" text="Nome" />
         <TextField fx:id="tfNome" layoutX="102.0" layoutY="70.0" />
         <TextField fx:id="tfSobrenome" layoutX="102.0" layoutY="107.0" />
         <Label fx:id="lbNomeCompleto" layoutX="102.0" layoutY="204.0" prefHeight="25.0" prefWidth="62.0" />
         <CheckBox fx:id="cbHabilitarEntrada" layoutX="103.0" layoutY="13.0" mnemonicParsing="false" onAction="#cbHabilitarEntradaOnAction" prefHeight="25.0" prefWidth="149.0" selected="true" text="Habilitar entrada" />
          <Button layoutX="115.0" layoutY="276.0" onAction="#onHelloButtonClick" text="Hello!" />
         <Label fx:id="lbIdade" layoutX="52.0" layoutY="150.0" text="Idade" />
         <TextField fx:id="tfIdade" layoutX="102.0" layoutY="146.0" />
      </children>
   </AnchorPane>
</VBox>
